# ============================================================
# AdamoServices Partner Manager — Plantilla de Variables de Entorno
#
# DESARROLLO : copiar como .env y ajustar.
# PRODUCCIÓN : NO uses este archivo físico. Inyecta cada variable
#              directamente en Railway → Service → Variables.
#
# ¡NUNCA subir el archivo .env al repositorio! (incluido en .gitignore)
# ============================================================

# --- Aplicación ---
APP_NAME="AdamoServices Partner Manager"
APP_ENV=production           # development | production
DEBUG=false                  # NUNCA true en producción (expone trazas de BD)

# --- Base de Datos ---
# PostgreSQL requerido. En desarrollo local usa docker compose up -d postgres.
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# --- Seguridad ---
# SECRET_KEY: Token URL-safe de 32 bytes (256 bits). NUNCA uses el valor por defecto.
# Genera uno nuevo con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Resultado ejemplo (¡genera el tuyo propio, no uses este!):
#   xK8mP2...  (43 caracteres, único por entorno)
SECRET_KEY=REEMPLAZAR_CON_SALIDA_DE_token_urlsafe_32

# Duración de sesión en minutos (GAFI R.1: minimizar ventana de sesión)
SESSION_TIMEOUT_MINUTES=30

# --- Administrador de Producción ---
# Requisitos CSBF / Circular 027: mínimo 16 chars, mayúsculas + minúsculas +
# dígitos + al menos 1 símbolo (!@#$%^&*...). No reutilizar passwords de desarrollo.
# Genera uno con:
#   python -c "import secrets,string; a=string.ascii_letters+string.digits+'!@#$%&*'; print(''.join(secrets.choice(a) for _ in range(20)))"
ADMIN_USERNAME=compliance_admin
ADMIN_PASSWORD=REEMPLAZAR_CON_PASSWORD_DE_ALTA_ENTROPIA
ADMIN_EMAIL=compliance@adamoservices.co

# --- Streamlit ---
# Railway inyecta $PORT automáticamente a través del entrypoint.sh.
# No definir STREAMLIT_SERVER_PORT en producción.
# STREAMLIT_SERVER_PORT=8501    ← solo desarrollo local
STREAMLIT_SERVER_ADDRESS=0.0.0.0
